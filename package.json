{
  "name": "suite-ctfl",
  "version": "1.0.0",
  "description": "Plataforma de estudo para a certificação ISTQB CTFL (Foundation Level): simulados, modo exame, resumo do syllabus, reforço por pontos fracos e progresso. Arquitetura limpa em TypeScript.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "istqb",
    "ctfl",
    "quiz",
    "clean-architecture",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "jsdom": "^25.0.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "motion": "^12.42.2"
  }
}
